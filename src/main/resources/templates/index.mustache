<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>커뮤니티</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>
<body>
{{> _nav}}
<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">게시글 목록</h4>
    <button class="btn btn-primary btn-sm" onclick="goCreate()">글쓰기</button>
  </div>
  <table class="table table-hover">
    <thead class="table-light">
      <tr>
        <th style="width:60px">번호</th>
        <th>제목</th>
        <th style="width:120px">작성자</th>
        <th style="width:160px">작성일</th>
      </tr>
    </thead>
    <tbody>
      {{#posts}}
      <tr style="cursor:pointer" onclick="location.href='/posts/{{id}}'">
        <td>{{id}}</td>
        <td>{{title}}</td>
        <td>{{nickname}}</td>
        <td>{{createdAt}}</td>
      </tr>
      {{/posts}}
      {{^posts}}
      <tr><td colspan="4" class="text-center text-muted py-4">게시글이 없습니다.</td></tr>
      {{/posts}}
    </tbody>
  </table>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function goCreate() {
    const user = JSON.parse(localStorage.getItem('user') || 'null');
    if (!user) { alert('로그인이 필요합니다.'); location.href = '/login'; return; }
    location.href = '/posts/create';
  }
</script>
</body>
</html>
