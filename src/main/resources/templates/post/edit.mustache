{{> _header}}
{{> _nav}}
<div id="pageData" data-post-id="{{post.id}}" data-post-category="{{post.category}}"></div>
<div class="container" style="max-width:720px">
  <div class="card shadow-sm">
    <div class="card-body p-4">
      <h5 class="card-title mb-4">게시글 수정</h5>
      <div class="mb-3">
        <label class="form-label">카테고리</label>
        <select id="category" class="form-select">
          <option value="EMPLOYMENT">취업</option>
          <option value="STUDY">공부</option>
          <option value="CONCERN">고민</option>
          <option value="FREE">자유</option>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label">제목</label>
        <input type="text" id="title" class="form-control" value="{{post.title}}">
      </div>
      <div class="mb-4">
        <label class="form-label">내용</label>
        <textarea id="content" class="form-control" rows="10">{{post.content}}</textarea>
      </div>
      <div class="d-flex gap-2 justify-content-end">
        <a href="/posts/{{post.id}}" class="btn btn-outline-secondary">취소</a>
        <button class="btn btn-primary" onclick="submit()">수정완료</button>
      </div>
    </div>
  </div>
</div>
<script src="/js/post/edit.js"></script>
{{> _footer}}
