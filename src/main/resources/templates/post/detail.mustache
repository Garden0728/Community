{{> _header}}
{{> _nav}}
<div id="pageData" data-post-id="{{post.id}}" data-post-user-id="{{post.userId}}"></div>
<div class="container" style="max-width:800px">
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="mb-2"><span class="badge bg-secondary">{{post.categoryName}}</span></div>
      <h4 class="card-title">{{post.title}}</h4>
      <p class="text-muted small mb-3">{{post.nickname}} · {{post.createdAt}}</p>
      <hr>
      <p class="card-text" style="white-space:pre-wrap">{{post.content}}</p>
    </div>
    <div class="card-footer d-flex gap-2 justify-content-end post-actions" style="display:none!important">
      <a href="/posts/{{post.id}}/edit" class="btn btn-outline-secondary btn-sm">수정</a>
      <button class="btn btn-outline-danger btn-sm" onclick="deletePost({{post.id}})">삭제</button>
    </div>
  </div>

  <h6 class="mb-3">댓글</h6>
  {{#comments}}
  <div class="card mb-2" id="comment-{{id}}">
    <div class="card-body py-2 px-3">
      <div class="comment-view">
        <p class="mb-1" style="white-space:pre-wrap">{{content}}</p>
        <div class="d-flex justify-content-between align-items-center">
          <small class="text-muted">{{nickname}} · {{createdAt}}</small>
          <div class="comment-actions gap-1" data-user-id="{{userId}}" style="display:none">
            <button class="btn btn-outline-secondary btn-sm py-0" onclick="showEditForm({{id}})">수정</button>
            <button class="btn btn-outline-danger btn-sm py-0" onclick="deleteComment({{id}})">삭제</button>
          </div>
        </div>
      </div>
      <div class="comment-edit" id="edit-{{id}}" style="display:none">
        <textarea class="form-control mb-1" id="edit-content-{{id}}" rows="2">{{content}}</textarea>
        <div class="d-flex gap-1 justify-content-end">
          <button class="btn btn-secondary btn-sm" onclick="hideEditForm({{id}})">취소</button>
          <button class="btn btn-primary btn-sm" onclick="submitEdit({{id}})">저장</button>
        </div>
      </div>
    </div>
  </div>
  {{/comments}}
  {{^comments}}
  <p class="text-muted text-center py-3">첫 댓글을 남겨보세요.</p>
  {{/comments}}

  <div class="card mt-3 shadow-sm" id="commentForm">
    <div class="card-body">
      <textarea id="commentContent" class="form-control mb-2" rows="2" placeholder="댓글을 입력하세요"></textarea>
      <div class="text-end">
        <button class="btn btn-primary btn-sm" onclick="submitComment({{post.id}})">등록</button>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <a href="/" class="btn btn-outline-secondary btn-sm">목록으로</a>
  </div>
</div>
<script src="/js/post/detail.js"></script>
{{> _footer}}
