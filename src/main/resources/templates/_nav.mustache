<nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">개발자 커뮤니티</a>
    <div class="ms-auto d-flex align-items-center gap-2" id="navAuth">
      <a href="/login" class="btn btn-outline-light btn-sm">로그인</a>
      <a href="/signup" class="btn btn-light btn-sm">회원가입</a>
    </div>
  </div>
</nav>
<script>
  (function() {
    const user = JSON.parse(localStorage.getItem('user') || 'null');
    if (user) {
      document.getElementById('navAuth').innerHTML =
        '<a href="/profile" class="btn btn-outline-light btn-sm">' + user.nickname + '님</a>' +
        '<button class="btn btn-outline-light btn-sm" onclick="logout()">로그아웃</button>';
    }
  })();
  function logout() {
    localStorage.removeItem('user');
    location.href = '/';
  }
</script>
