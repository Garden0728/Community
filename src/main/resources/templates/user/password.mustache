{{> _header}}
{{> _nav}}
<div class="container" style="max-width:480px">
  <div class="card shadow-sm">
    <div class="card-header fw-bold">비밀번호 변경</div>
    <div class="card-body">
      <div class="mb-3">
        <label class="form-label text-muted small">현재 비밀번호</label>
        <input type="password" id="currentPassword" class="form-control">
      </div>
      <div class="mb-3">
        <label class="form-label text-muted small">새 비밀번호</label>
        <input type="password" id="newPassword" class="form-control">
      </div>
      <div class="mb-4">
        <label class="form-label text-muted small">새 비밀번호 확인</label>
        <input type="password" id="newPasswordConfirm" class="form-control">
      </div>
      <div id="pwMsg" class="alert d-none"></div>
      <div class="d-flex gap-2">
        <a href="/profile" class="btn btn-outline-secondary w-50">취소</a>
        <button class="btn btn-primary w-50" onclick="changePassword()">변경</button>
      </div>
    </div>
  </div>
</div>
<script src="/js/user/password.js"></script>
{{> _footer}}
