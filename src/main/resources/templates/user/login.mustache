{{> _header}}
{{> _nav}}
<div class="container" style="max-width:420px">
  <div class="card shadow-sm">
    <div class="card-body p-4">
      <h5 class="card-title mb-4 text-center">로그인</h5>
      <div id="errorMsg" class="alert alert-danger d-none"></div>
      <div class="mb-3">
        <label class="form-label">아이디</label>
        <input type="text" id="loginId" class="form-control" placeholder="아이디 입력">
      </div>
      <div class="mb-4">
        <label class="form-label">비밀번호</label>
        <input type="password" id="password" class="form-control" placeholder="비밀번호 입력">
      </div>
      <button class="btn btn-primary w-100" onclick="doLogin()">로그인</button>
      <p class="text-center mt-3 mb-0 text-muted small">
        계정이 없으신가요? <a href="/signup">회원가입</a> ·
        <a href="/find-password">비밀번호 찾기</a>
      </p>
    </div>
  </div>
</div>
<script>
  async function doLogin() {
    const loginId = document.getElementById('loginId').value;
    const password = document.getElementById('password').value;
    const res = await fetch('/api/users/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ loginId, password })
    });
    const data = await res.json();
    if (res.ok) {
      localStorage.setItem('user', JSON.stringify({ userId: data.userId, loginId: data.loginId, nickname: data.nickname }));
      location.href = '/';
    } else {
      const el = document.getElementById('errorMsg');
      el.textContent = data.message;
      el.classList.remove('d-none');
    }
  }
  document.addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
</script>
{{> _footer}}
