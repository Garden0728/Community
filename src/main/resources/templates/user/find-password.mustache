{{> _header}}
{{> _nav}}
<div class="container" style="max-width:440px">
  <div class="card shadow-sm">
    <div class="card-header fw-bold">비밀번호 찾기</div>
    <div class="card-body p-4">
      <div id="step1">
        <div class="mb-3">
          <label class="form-label">아이디</label>
          <input type="text" id="loginId" class="form-control" placeholder="아이디 입력">
        </div>
        <div class="mb-4">
          <label class="form-label">전화번호</label>
          <input type="text" id="phone" class="form-control" placeholder="010-1234-5678">
        </div>
        <div id="verifyMsg" class="alert d-none"></div>
        <button class="btn btn-primary w-100" onclick="verify()">본인 확인</button>
        <p class="text-center mt-3 mb-0 text-muted small">
          <a href="/login">로그인으로 돌아가기</a>
        </p>
      </div>
      <div id="step2" style="display:none">
        <p class="text-success mb-3">본인 확인이 완료되었습니다. 새 비밀번호를 입력하세요.</p>
        <div class="mb-3">
          <label class="form-label">새 비밀번호</label>
          <input type="password" id="newPassword" class="form-control">
        </div>
        <div class="mb-4">
          <label class="form-label">새 비밀번호 확인</label>
          <input type="password" id="newPasswordConfirm" class="form-control">
        </div>
        <div id="resetMsg" class="alert d-none"></div>
        <button class="btn btn-primary w-100" onclick="resetPassword()">비밀번호 변경</button>
      </div>
    </div>
  </div>
</div>
<script src="/js/user/find-password.js"></script>
{{> _footer}}
